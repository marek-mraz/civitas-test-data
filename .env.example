# Copy to .env (or set these in Dokploy -> Environment).
#
# The passwords are REQUIRED — the stack refuses to start without them.
# These services are reachable from the internet: use long, random,
# unique passwords, e.g.:  openssl rand -base64 24

# PostgreSQL (master data source)
POSTGRES_DB=smartmeter
POSTGRES_USER=civitas
POSTGRES_PASSWORD=
POSTGRES_PORT=5432

# Mosquitto (measurement data source) — TLS only, plaintext is not published
MQTT_USER=civitas
MQTT_PASSWORD=
MQTT_TLS_PORT=8883

# Hostname clients use to reach the services (goes into the auto-generated
# TLS certificate — only matters if a client chooses to verify the cert)
PUBLIC_HOSTNAME=localhost

# Simulator
MQTT_BASE_TOPIC=taf10/sensors
PUBLISH_INTERVAL_SECONDS=15
